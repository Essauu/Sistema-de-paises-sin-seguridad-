@model PaisApp.Models.City
@{
    ViewData["Title"] = "Editar Ciudad - " + Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil me-2"></i>Editar @Model.Name</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-building me-2"></i>Información</h5></div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" maxlength="35" required />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CountryCode" class="form-label">País</label>
                        <select asp-for="CountryCode" class="form-select" asp-items="@ViewBag.Countries" required></select>
                        <span asp-validation-for="CountryCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="District" class="form-label"></label>
                        <input asp-for="District" class="form-control" maxlength="20" required />
                        <span asp-validation-for="District" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Population" class="form-label"></label>
                        <input asp-for="Population" type="number" min="0" class="form-control" required />
                        <span asp-validation-for="Population" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning"><i class="bi bi-save me-1"></i>Guardar Cambios</button>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>