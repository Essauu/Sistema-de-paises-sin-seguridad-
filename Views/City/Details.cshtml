@model PaisApp.Models.City
@{
    ViewData["Title"] = "Ciudad - " + Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-building me-2"></i>@Model.Name</h2>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning"><i class="bi bi-pencil me-1"></i>Editar</a>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Información</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Nombre</dt>
                    <dd class="col-sm-8">@Model.Name</dd>
                    <dt class="col-sm-4">País</dt>
                    <dd class="col-sm-8">
                        <a asp-controller="Country" asp-action="Details" asp-route-id="@Model.CountryCode">
                            @Model.Country?.Name (@Model.CountryCode)
                        </a>
                    </dd>
                    <dt class="col-sm-4">Distrito</dt>
                    <dd class="col-sm-8">@Model.District</dd>
                    <dt class="col-sm-4">Población</dt>
                    <dd class="col-sm-8">@Model.Population.ToString("N0")</dd>
                    <dt class="col-sm-4">Es Capital</dt>
                    <dd class="col-sm-8">
                        @if (Model.Country?.Capital == Model.Id)
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-star-fill me-1"></i>Capital del país</span>
                        }
                        else
                        {
                            <span class="text-muted">No</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>