@model PaisApp.Models.CountryLanguage
@{
    ViewData["Title"] = "Nuevo Idioma";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-plus-circle me-2"></i>Nuevo Idioma</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5 class="mb-0"><i class="bi bi-translate me-2"></i>Información</h5></div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="CountryCode" class="form-label">País</label>
                        <select asp-for="CountryCode" class="form-select" asp-items="@ViewBag.Countries" required>
                            <option value="">Seleccionar país</option>
                        </select>
                        <span asp-validation-for="CountryCode" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Language" class="form-label"></label>
                        <input asp-for="Language" class="form-control" maxlength="30" required />
                        <span asp-validation-for="Language" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IsOfficial" class="form-label">¿Es oficial?</label>
                        <select asp-for="IsOfficial" class="form-select" required>
                            <option value="F">No</option>
                            <option value="T">Sí</option>
                        </select>
                        <span asp-validation-for="IsOfficial" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Percentage" class="form-label">Porcentaje de hablantes</label>
                        <input asp-for="Percentage" type="number" step="0.1" min="0" max="100" class="form-control" required />
                        <span asp-validation-for="Percentage" class="text-danger"></span>
                    </div>

                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Guardar</button>
                        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-circle me-1"></i>Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>