@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <i class="bi bi-shield-exclamation" style="font-size: 5rem; color: #dc3545;"></i>
            <h1 class="mt-3 text-danger">Acceso Denegado</h1>
            <p class="text-muted">No tiene permisos suficientes para acceder a esta página.</p>
            <p class="text-muted">Su cuenta tiene nivel <strong>@User.FindFirst("Nivel")?.Value</strong> (consulta). Se requiere nivel 2 o superior para modificar.</p>
            <a asp-action="Index" asp-controller="Home" class="btn btn-primary"><i class="bi bi-house me-1"></i>Ir al Inicio</a>
        </div>
    </div>
</div>