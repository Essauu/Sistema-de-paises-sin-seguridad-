@model PaisApp.Models.Country
@{
    ViewData["Title"] = "Editar País - " + Model.Name;
    var continents = (List<string>)ViewBag.Continents!;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-pencil me-2"></i>Editar @Model.Name (@Model.Code)</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Code" />
    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-flag me-2"></i>Información Básica</h5></div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label asp-for="Code" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Code" class="form-control" maxlength="3" readonly />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Code2" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Code2" class="form-control" maxlength="2" required />
                            <span asp-validation-for="Code2" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Name" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Name" class="form-control" maxlength="52" required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="LocalName" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="LocalName" class="form-control" maxlength="45" required />
                            <span asp-validation-for="LocalName" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Continent" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <select asp-for="Continent" class="form-select" asp-items="@(new SelectList(continents))" required></select>
                            <span asp-validation-for="Continent" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Region" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Region" class="form-control" maxlength="26" required />
                            <span asp-validation-for="Region" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-graph-up me-2"></i>Estadísticas</h5></div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label asp-for="SurfaceArea" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="SurfaceArea" type="number" step="0.01" min="0" class="form-control" required />
                            <span asp-validation-for="SurfaceArea" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Population" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Population" type="number" min="0" class="form-control" required />
                            <span asp-validation-for="Population" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="LifeExpectancy" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="LifeExpectancy" type="number" step="0.1" min="0" max="120" class="form-control" />
                            <span asp-validation-for="LifeExpectancy" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="GNP" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="GNP" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="GNP" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="GNPOld" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="GNPOld" type="number" step="0.01" class="form-control" />
                            <span asp-validation-for="GNPOld" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="IndepYear" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="IndepYear" type="number" min="0" max="@DateTime.Now.Year" class="form-control" />
                            <span asp-validation-for="IndepYear" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-building me-2"></i>Gobierno y Capital</h5></div>
                <div class="card-body">
                    <div class="row mb-3">
                        <label asp-for="GovernmentForm" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="GovernmentForm" class="form-control" maxlength="45" required />
                            <span asp-validation-for="GovernmentForm" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="HeadOfState" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="HeadOfState" class="form-control" maxlength="60" />
                            <span asp-validation-for="HeadOfState" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Capital" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <select asp-for="Capital" class="form-select" asp-items="@ViewBag.Cities">
                                <option value="">Seleccionar capital (opcional)</option>
                            </select>
                            <span asp-validation-for="Capital" class="text-danger"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card mb-4">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-image me-2"></i>Bandera (Opcional)</h5></div>
                <div class="card-body">
                    <div class="text-center mb-3">
                        <img src="https://flagcdn.com/64x48/@(Model.Code2.ToLower()).png"
                             alt="Bandera de @Model.Name"
                             class="img-thumbnail"
                             style="max-height: 100px;"
                             onerror="this.style.display='none'" />
                        <small class="d-block text-muted">Bandera actual (flagcdn.com)</small>
                    </div>
                    <input type="file" name="flagFile" class="form-control" accept="image/*" />
                    <div class="form-text">Formatos: JPG, PNG, GIF, WebP, BMP. Máx 5MB</div>
                </div>
            </div>
            <div class="card">
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-warning btn-lg">
                            <i class="bi bi-save me-2"></i>Guardar Cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-x-circle me-2"></i>Cancelar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>