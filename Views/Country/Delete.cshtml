@model PaisApp.Models.Country
@{
    ViewData["Title"] = "Eliminar País - " + Model.Name;
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirmar Eliminación</h5>
            </div>
            <div class="card-body text-center">
                <i class="bi bi-flag" style="font-size: 4rem; color: #dc3545;"></i>
                <h3 class="mt-3">@Model.Name</h3>
                <p class="text-muted">Código: <code>@Model.Code</code></p>
                <p class="text-danger fw-bold">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    ¿Está seguro de eliminar este país? Esta acción no se puede deshacer.
                </p>

                @if (Model.Cities?.Count > 0 || Model.CountryLanguages?.Count > 0)
                {
                    <div class="alert alert-warning">
                        <strong>Advertencia:</strong> Este país tiene
                        @(Model.Cities?.Count ?? 0) ciudades y
                        @(Model.CountryLanguages?.Count ?? 0) idiomas asociados.
                        Se eliminarán también.
                    </div>
                }
            </div>
            <div class="card-footer d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i>Cancelar
                </a>
                <form asp-action="Delete" method="post">
                    <input type="hidden" name="id" value="@Model.Code" />
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>